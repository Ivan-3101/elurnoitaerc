            <camunda:inputParameter name="stage4InputParams">[{"key":"context","type":"minioJson","value":"##contextMinioPath##","sourceJsonPath":"$"}]</camunda:inputParameter>
            <camunda:inputParameter name="stage4OutputMapping">[{"type":"var","key":"agentAction","jsonPath":"$.action"},{"type":"var","key":"agentStatus","jsonPath":"$.status"},{"type":"var","key":"agentQuestions","jsonPath":"$.questions"},{"type":"var","key":"agentMissingFields","jsonPath":"$.missing_fields"},{"type":"var","key":"agentConfidence","jsonPath":"$.confidence"},{"type":"minio","key":"master-parameter-agent_output","jsonPath":"$"}]</camunda:inputParameter>
            <camunda:inputParameter name="stage5InputParams">[{"key":"context","type":"minioJson","value":"##contextMinioPath##","sourceJsonPath":"$"}]</camunda:inputParameter>
