      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_019ztt8_di" bpmnElement="PrintUserInput">
        <dc:Bounds x="620" y="140" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1bcykc0_di" bpmnElement="Flow_1bcykc0">
        <di:waypoint x="568" y="180" />
        <di:waypoint x="620" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0qoebua_di" bpmnElement="Flow_0qoebua">
