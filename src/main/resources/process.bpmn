      <bpmn:endEvent id="Event_1b6lard">
        <bpmn:incoming>Flow_0qoebua</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_0qoebua" sourceRef="PrintUserInput" targetRef="Event_1b6lard" />
      <bpmn:serviceTask id="PrintUserInput" name="Print User Input" camunda:class="com.DronaPay.frm.ruleCreation.PrintUserInputDelegate">
        <bpmn:extensionElements />
        <bpmn:incoming>Flow_1bcykc0</bpmn:incoming>
        <bpmn:outgoing>Flow_0qoebua</bpmn:outgoing>
      </bpmn:serviceTask>
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_0lxt7vk" sourceRef="Activity_0ub2wih" targetRef="Event_1k8lbfd" />
    <bpmn:sequenceFlow id="Flow_1axt5ei" sourceRef="Activity_0g6e4fy" targetRef="Activity_0ub2wih" />
    <bpmn:serviceTask id="Activity_0g6e4fy" name="Generate TicketID and Workflow Name" camunda:modelerTemplate="com.dronapay.generic.ticketgenerator.v2" camunda:class="com.DronaPay.generic.delegates.GenericTicketIdGenerator_V2">
      <bpmn:extensionElements>
        <camunda:field name="stageConfig">
          <camunda:string>{
  "steps": [
    {
      "key": "InsertTicketId",
      "type": "SqlQueryExecution",
      "config": {
        "query": "INSERT INTO ui.ticketidgenerator(processinstanceid) VALUES (?)",
        "queryType": "update",
        "parameters": [
          { "key": "processInstanceId", "type": "string" }
        ]
      }
    },
    {
      "key": "GetTicketId",
      "type": "SqlQueryExecution",
      "config": {
        "query": "SELECT ticketid FROM ui.ticketidgenerator WHERE processinstanceid = ?",
        "queryType": "select",
        "parameters": [
          { "key": "processInstanceId", "type": "string" }
        ]
      },
      "returnValueKey": "ticketid",
      "returnValueObjKey": "TicketID",
      "processVariablesToSetAfterExecution": [
        { "key": "TicketID", "path": "TicketID" }
      ]
    },
    {
      "key": "FetchAccountAttribs",
      "type": "SqlQueryExecution",
      "config": {
        "query": "select vcattribs from masters.accounts where vcexternalaccountid = ?",
        "queryType": "select",
        "parameters": [
          { "key": "policy_id", "type": "string" }
        ]
      },
      "returnValueKey": "vcattribs",
      "returnValueObjKey": "accountAttribs",
      "processVariablesToSetAfterExecution": [
        { "key": "accountAttribs", "path": "vcattribs" }
      ]
    },
    {
      "key": "FetchVpaAttribs",
      "type": "SqlQueryExecution",
      "config": {
        "query": "select v.vcattribs from masters.vpa as v join (select iaccountid from masters.accounts where vcexternalaccountid = ?) as a on v.iaccountid = a.iaccountid where v.vcexternaladdressid = ?",
        "queryType": "select",
        "parameters": [
          { "key": "policy_id", "type": "string" },
          { "key": "holder_name", "type": "string" }
        ]
      },
      "returnValueKey": "vcattribs",
      "returnValueObjKey": "vpaAttribs",
      "processVariablesToSetAfterExecution": [
        { "key": "vpaAttribs", "path": "vcattribs" }
      ]
    }
  ],
  "initialVariablesRootObj": [
    { "key": "tenantId", "executionMethod": true },
    { "key": "workflowKey", "executionMethod": true },
    { "key": "processInstanceId", "executionMethod": true },
    { "key": "stageName", "executionMethod": true },
    { "key": "userInput", "processVariable": true },
    { "key": "policy_id", "processVariable": true },
    { "key": "holder_name", "processVariable": true }
  ]
}</camunda:string>
        </camunda:field>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_14w7cro</bpmn:incoming>
      <bpmn:outgoing>Flow_1axt5ei</bpmn:outgoing>
    </bpmn:serviceTask>
  </bpmn:process>
