<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1funpwf" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.39.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.23.0">
  <bpmn:process id="RuleCreation" name="Rule Creation" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_14w7cro</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_14w7cro" sourceRef="StartEvent_1" targetRef="Activity_0g6e4fy" />
    <bpmn:endEvent id="Event_1k8lbfd">
      <bpmn:incoming>Flow_0hkcf7q</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1axt5ei" sourceRef="Activity_0g6e4fy" targetRef="Activity_1h0xj8c" />
    <bpmn:serviceTask id="Activity_0g6e4fy" name="Generate TicketID and Workflow Name" camunda:modelerTemplate="com.dronapay.generic.ticketgenerator.v2" camunda:class="com.DronaPay.generic.delegates.GenericTicketIdGenerator_V2">
      <bpmn:extensionElements>
        <camunda:field name="stageConfig">
          <camunda:string>{
  "steps": [
    {
      "key": "InsertTicketId",
      "type": "SqlQueryExecution",
      "config": {
        "query": "INSERT INTO ui.ticketidgenerator(processinstanceid) VALUES (?)",
        "queryType": "update",
        "parameters": [
          { "key": "processInstanceId", "type": "string" }
        ]
      }
    },
    {
      "key": "GetTicketId",
      "type": "SqlQueryExecution",
      "config": {
        "query": "SELECT ticketid FROM ui.ticketidgenerator WHERE processinstanceid = ?",
        "queryType": "select",
        "parameters": [
          { "key": "processInstanceId", "type": "string" }
        ]
      },
      "returnValueKey": "ticketid",
      "returnValueObjKey": "TicketID",
      "processVariablesToSetAfterExecution": [
        { "key": "TicketID", "path": "TicketID" }
      ]
    },
    {
      "key": "FetchAccountAttribs",
      "type": "SqlQueryExecution",
      "config": {
        "query": "select vcattribs from masters.accounts where vcexternalaccountid = ?",
        "queryType": "select",
        "parameters": [
          { "key": "policy_id", "type": "string" }
        ]
      },
      "returnValueKey": "vcattribs",
      "returnValueObjKey": "accountAttribs",
      "processVariablesToSetAfterExecution": [
        { "key": "accountAttribs", "path": "vcattribs" }
      ]
    },
    {
      "key": "FetchVpaAttribs",
      "type": "SqlQueryExecution",
      "config": {
        "query": "select v.vcattribs from masters.vpa as v join (select iaccountid from masters.accounts where vcexternalaccountid = ?) as a on v.iaccountid = a.iaccountid where v.vcexternaladdressid = ?",
        "queryType": "select",
        "parameters": [
          { "key": "policy_id", "type": "string" },
          { "key": "holder_name", "type": "string" }
        ]
      },
      "returnValueKey": "vcattribs",
      "returnValueObjKey": "vpaAttribs",
      "processVariablesToSetAfterExecution": [
        { "key": "vpaAttribs", "path": "vcattribs" }
      ]
    }
  ],
  "initialVariablesRootObj": [
    { "key": "tenantId", "executionMethod": true },
    { "key": "workflowKey", "executionMethod": true },
    { "key": "processInstanceId", "executionMethod": true },
    { "key": "stageName", "executionMethod": true },
    { "key": "userInput", "processVariable": true },
    { "key": "policy_id", "processVariable": true },
    { "key": "holder_name", "processVariable": true }
  ]
}</camunda:string>
        </camunda:field>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_14w7cro</bpmn:incoming>
      <bpmn:outgoing>Flow_1axt5ei</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:subProcess id="Activity_1h0xj8c">
      <bpmn:incoming>Flow_1axt5ei</bpmn:incoming>
      <bpmn:outgoing>Flow_0hkcf7q</bpmn:outgoing>
      <bpmn:startEvent id="Event_1544p4x">
        <bpmn:outgoing>Flow_0vgn3zw</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:exclusiveGateway id="Gateway_12sh51j">
        <bpmn:incoming>Flow_1scutn9</bpmn:incoming>
        <bpmn:outgoing>Flow_1epidy7</bpmn:outgoing>
        <bpmn:outgoing>Flow_1vty2u8</bpmn:outgoing>
        <bpmn:outgoing>Flow_148cdqt</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:userTask id="Activity_13uk4oo" name="x.UserTask" camunda:formKey="embedded:app:forms/agent-user-task-form.html">
        <bpmn:incoming>Flow_1vty2u8</bpmn:incoming>
        <bpmn:outgoing>Flow_0rw7fbe</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:endEvent id="Event_07kupp5" name="Agent-Orchestrator Loop Complete">
        <bpmn:incoming>Flow_148cdqt</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_0vgn3zw" sourceRef="Event_1544p4x" targetRef="Orchestrator" />
      <bpmn:sequenceFlow id="Flow_0l43wcn" sourceRef="Generic_Agent" targetRef="Orchestrator" />
      <bpmn:sequenceFlow id="Flow_0rw7fbe" sourceRef="Activity_13uk4oo" targetRef="Orchestrator" />
      <bpmn:sequenceFlow id="Flow_1scutn9" sourceRef="Orchestrator" targetRef="Gateway_12sh51j" />
      <bpmn:sequenceFlow id="Flow_1epidy7" name="CONTINUE / RETRY_STEP" sourceRef="Gateway_12sh51j" targetRef="Generic_Agent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${orchestratorAction == 'CONTINUE' || orchestratorAction == 'RETRY_STEP'}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_1vty2u8" name="GO_USER_TASK" sourceRef="Gateway_12sh51j" targetRef="Activity_13uk4oo">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${orchestratorAction == 'GO_USER_TASK'}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_148cdqt" name="EXIT" sourceRef="Gateway_12sh51j" targetRef="Event_07kupp5">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${orchestratorAction == 'EXIT'}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:serviceTask id="Generic_Agent" name="Generic Agent" camunda:modelerTemplate="com.dronapay.generic.orchestrator.agent" camunda:class="com.DronaPay.generic.delegates.OrchestratorAgentDelegate">
        <bpmn:extensionElements>
          <camunda:field name="agentId">
            <camunda:string>${currentAgentId}</camunda:string>
          </camunda:field>
          <camunda:field name="baseUrl">
            <camunda:string>dia</camunda:string>
          </camunda:field>
          <camunda:field name="route">
            <camunda:string>agent</camunda:string>
          </camunda:field>
          <camunda:field name="authType">
            <camunda:string>basicAuth</camunda:string>
          </camunda:field>
          <camunda:field name="method">
            <camunda:string>POST</camunda:string>
          </camunda:field>
          <camunda:field name="inputParams">
            <camunda:string>${currentInputParams}</camunda:string>
          </camunda:field>
          <camunda:field name="outputMapping">
            <camunda:string>${currentOutputMapping}</camunda:string>
          </camunda:field>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1epidy7</bpmn:incoming>
        <bpmn:outgoing>Flow_0l43wcn</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Orchestrator" name="Orchestrator" camunda:modelerTemplate="com.dronapay.generic.orchestrator" camunda:class="com.DronaPay.generic.delegates.OrchestratorDelegate">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="stage1InputParams">[{"key":"context","type":"minioJson","value":"##contextMinioPath##","sourceJsonPath":"$"}]</camunda:inputParameter>
            <camunda:inputParameter name="stage1OutputMapping">[{"type":"var","key":"agentAction","jsonPath":"$.action"},{"type":"var","key":"agentStatus","jsonPath":"$.status"},{"type":"var","key":"agentQuestions","jsonPath":"$.questions"},{"type":"var","key":"agentMissingFields","jsonPath":"$.missing_fields"},{"type":"var","key":"agentConfidence","jsonPath":"$.confidence"},{"type":"minio","key":"execution-mode-agent_output","jsonPath":"$"}]</camunda:inputParameter>
            <camunda:inputParameter name="stage2InputParams">[{"key":"context","type":"minioJson","value":"##contextMinioPath##","sourceJsonPath":"$"}]</camunda:inputParameter>
            <camunda:inputParameter name="stage2OutputMapping">[{"type":"var","key":"agentAction","jsonPath":"$.action"},{"type":"var","key":"agentStatus","jsonPath":"$.status"},{"type":"var","key":"agentQuestions","jsonPath":"$.questions"},{"type":"var","key":"agentMissingFields","jsonPath":"$.missing_fields"},{"type":"var","key":"agentConfidence","jsonPath":"$.confidence"},{"type":"minio","key":"product-class-agent_output","jsonPath":"$"}]</camunda:inputParameter>
            <camunda:inputParameter name="stage3InputParams">[{"key":"context","type":"minioJson","value":"##contextMinioPath##","sourceJsonPath":"$"}]</camunda:inputParameter>
